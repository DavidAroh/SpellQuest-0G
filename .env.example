# ── SpellQuest × 0G configuration ────────────────────────────────────────────
# Copy to .env.local and fill in. Only VITE_* vars reach the browser bundle.

# Deployed SpellQuestLeaderboard contract on 0G Galileo testnet (chain 16602).
# Leave blank until you deploy it (see contracts/DEPLOY.md). The leaderboard
# UI degrades gracefully to an empty board when unset.
VITE_OG_LEADERBOARD_ADDRESS=

# ── Spell Sage AI agent — 0G Compute (optional) ──────────────────────────────
# When set, the on-screen Sage's lines are generated by a model on 0G's compute
# network. When blank, the Sage uses its built-in local coach (always works).
#
# RECOMMENDED: run the proxy (npm run og:proxy) so the key stays server-side and
# CORS works, then point the app at the proxy:
VITE_OG_COMPUTE_ENDPOINT=http://localhost:8787
# Pick a CHAT model from pc.testnet.0g.ai/models and paste its exact id (click the
# copy icon next to the name). Testnet's chat model is Qwen2.5-Omni.
VITE_OG_COMPUTE_MODEL=Qwen2.5-Omni
# VITE_OG_COMPUTE_API_KEY is only needed if you call a provider DIRECTLY from the
# browser (dev only — it WILL be exposed in the bundle). Leave blank when using
# the proxy.
VITE_OG_COMPUTE_API_KEY=

# ── Server-side only (never bundled) ─────────────────────────────────────────
# 0G Compute Router API key — get it + deposit 0G at https://pc.testnet.0g.ai
OG_COMPUTE_API_KEY=
# Router base URL (testnet default shown). Override for mainnet: https://router-api.0g.ai/v1
OG_COMPUTE_BASE_URL=https://router-api-testnet.integratenetwork.work/v1
# OG_PROXY_PORT=8787

# Private key of a funded 0G testnet wallet (used by contracts/deploy.mjs).
# KEEP THIS SECRET — .env is gitignored.
OG_DEPLOYER_PRIVATE_KEY=
